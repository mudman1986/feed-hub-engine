{
  "name": "feed-hub-engine",
  "version": "1.0.0",
  "description": "Feed Hub Engine - Shared RSS aggregation workflows and demo site",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jest": "^30.0.0",
    "http-server": "^14.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "playwright": "^1.59.1"
  },
  "jest": {
    "projects": [
      {
        "displayName": "browser",
        "testEnvironment": "jsdom",
        "testMatch": [
          "**/tests/js/**/*.test.js"
        ],
        "collectCoverageFrom": [
          "src/site/script.js"
        ]
      }
    ]
  },
  "standard": {
    "ignore": [
      "**/*.test.js",
      "**/*.spec.js",
      "tests/**",
      "test/**",
      "playwright.config.js"
    ]
  }
}
